FROM node:18-alpine

WORKDIR /app

# Build-time env vars (Vite bakes these into the bundle at build time)
ARG VITE_INSURER_API_URL=http://127.0.0.1:8004
ARG VITE_PLATFORM_API_URL=http://127.0.0.1:8004
ARG VITE_WORKER_API_URL=http://127.0.0.1:8004
ARG VITE_ML_API_URL=http://127.0.0.1:9000
ARG VITE_GATEWAY_API_URL=http://127.0.0.1:8004
ARG VITE_CORE_API_URL=http://127.0.0.1:8004
ENV VITE_INSURER_API_URL=${VITE_INSURER_API_URL}
ENV VITE_PLATFORM_API_URL=${VITE_PLATFORM_API_URL}
ENV VITE_WORKER_API_URL=${VITE_WORKER_API_URL}
ENV VITE_ML_API_URL=${VITE_ML_API_URL}
ENV VITE_GATEWAY_API_URL=${VITE_GATEWAY_API_URL}
ENV VITE_CORE_API_URL=${VITE_CORE_API_URL}

COPY package*.json ./
RUN npm install

COPY . .
RUN npm run build

FROM node:18-alpine
RUN npm install -g serve

WORKDIR /app
COPY --from=0 /app/dist ./dist

EXPOSE 5173
CMD ["serve", "-s", "dist", "-l", "5173"]
