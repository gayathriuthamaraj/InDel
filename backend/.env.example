# Preferred for production (Supabase, Render, etc.)
# Use the full connection string from Supabase (prefer pooler endpoint for IPv4-only runtimes).
# Example: postgresql://postgres:YOUR_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=

# Optional override when DATABASE_URL is not used.
# If unset, backend defaults to:
# - disable for localhost/127.0.0.1/postgres
# - require for all other hosts
DB_SSLMODE=

# Fallback discrete settings for local/docker usage.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=indel
DB_PASSWORD=password
DB_NAME=indel

JWT_SECRET=indel-dev-secret
INDEL_ENV=development
LOG_LEVEL=info

# KeepAlive poller targets (core service). Prefer setting one of:
# 1) KEEPALIVE_URLS (comma-separated full health URLs)
# 2) PUBLIC_CORE_URL (base URL, /health is appended)
# 3) RENDER_EXTERNAL_URL (base URL, /health is appended)
# KEEPALIVE_URLS=https://indel-backend.onrender.com/health
# PUBLIC_CORE_URL=https://indel-backend.onrender.com
