# Platform Dashboard Environment Variables
# Recommended: point all API URLs to API Gateway (port 8004) in local/dev.
VITE_PLATFORM_API_URL=http://127.0.0.1:8004
VITE_CORE_API_URL=http://127.0.0.1:8000
# Points workerClient to worker-gateway (routes: /api/v1/worker/*, /api/v1/demo/*)
VITE_WORKER_API_URL=http://127.0.0.1:8001
VITE_FORECAST_API_URL=http://127.0.0.1:9000
VITE_PLATFORM_WEBHOOK_KEY=change-me-platform-webhook-key
