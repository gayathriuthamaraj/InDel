FROM node:18-alpine

WORKDIR /app

ARG VITE_PLATFORM_API_URL=http://127.0.0.1:8004
ARG VITE_CORE_API_URL=http://127.0.0.1:8000
ARG VITE_WORKER_API_URL=http://127.0.0.1:8001
ARG VITE_FORECAST_API_URL=http://127.0.0.1:9000
ENV VITE_PLATFORM_API_URL=${VITE_PLATFORM_API_URL}
ENV VITE_CORE_API_URL=${VITE_CORE_API_URL}
ENV VITE_WORKER_API_URL=${VITE_WORKER_API_URL}
ENV VITE_FORECAST_API_URL=${VITE_FORECAST_API_URL}

COPY package*.json ./
RUN npm install

COPY . .
RUN npm run build

FROM node:18-alpine
RUN npm install -g serve

WORKDIR /app
COPY --from=0 /app/dist ./dist

EXPOSE 5175
CMD ["serve", "-s", "dist", "-l", "5175"]
