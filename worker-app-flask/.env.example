# Worker App Flask Frontend Configuration
# Copy this file to .env and update values as needed

# Backend API base URL (worker routes)
# Direct worker gateway: http://127.0.0.1:8001
# Nginx gateway (if configured): http://127.0.0.1:8004
# Physical device/LAN: use your machine IP with the same port
API_BASE_URL=http://127.0.0.1:8001

# Flask secret key (change in production)
SECRET_KEY=dev-secret-change-me

# Flask debug mode
FLASK_DEBUG=true

# Optional cookie hardening
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=false
